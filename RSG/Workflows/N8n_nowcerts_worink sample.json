    {
      "parameters": {
        "jsCode": "/* NORMALIZE POLICIES — data transform only, no API calls */\n\nconst rawInput = $input.all();\nconst policies = rawInput[0]?.json?.value || rawInput.map(i => i.json);\n\nlet total = 0;\nconst normalized = [];\n\nfor (const p of policies) {\n  const policyNumber = p.number || '';\n  if (!policyNumber) continue;\n\n  const insuredName = p.insuredCommercialName\n    || ((p.insuredFirstName || '') + ' ' + (p.insuredLastName || '')).trim()\n    || 'Unknown';\n\n  const lobArray = Array.isArray(p.lineOfBusinesses)\n    ? p.lineOfBusinesses.map(l => (typeof l === 'string' ? l : (l.lineOfBusinessName || '')))\n    : [];\n  const lobString = lobArray.join(', ');\n\n  const cleanDate = (d) => d ? d.split('T')[0] : null;\n\n  total++;\n  normalized.push({\n    json: {\n      nowcertsId:     p.databaseId           || '',\n      insuredId:      p.insuredDatabaseId     || '',\n      insuredName,\n      policyNumber,\n      lineOfBusiness: lobString,\n      carrier:        p.carrierName           || '',\n      effectiveDate:  cleanDate(p.effectiveDate),\n      expirationDate: cleanDate(p.expirationDate),\n      premium:        parseFloat(p.totalPremium) || 0,\n      status:         p.status                || '',\n      businessType:   p.businessType          || ''\n    }\n  });\n}\n\nconsole.log('Policies normalized:', total);\nreturn normalized;"
      },
      "id": "e5fd5e71-7b99-49e4-8d9b-4577342201c4",
      "name": "🔧 Normalize Policies",

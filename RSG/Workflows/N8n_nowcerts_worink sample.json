        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"properties\": {\n    \"Policy Number\": { \"title\": [{ \"text\": { \"content\": \"{{ $('🔄 Split In Batches').item.json.policyNumber }}\" } }] },\n    \"Named Insured\": { \"rich_text\": [{ \"text\": { \"content\": \"{{ $('🔄 Split In Batches').item.json.insuredName }}\" } }] },\n    \"Carrier\": { \"rich_text\": [{ \"text\": { \"content\": \"{{ $('🔄 Split In Batches').item.json.carrier }}\" } }] },\n    \"Lines Of Business\": { \"rich_text\": [{ \"text\": { \"content\": \"{{ $('🔄 Split In Batches').item.json.lineOfBusiness }}\" } }] },\n    \"Effective Date\": { \"date\": {{ $('🔄 Split In Batches').item.json.effectiveDate ? '{ \"start\": \"' + $('🔄 Split In Batches').item.json.effectiveDate + '\" }' : 'null' }} },\n    \"Expiration Date\": { \"date\": {{ $('🔄 Split In Batches').item.json.expirationDate ? '{ \"start\": \"' + $('🔄 Split In Batches').item.json.expirationDate + '\" }' : 'null' }} },\n    \"Premium Amount\": { \"number\": {{ $('🔄 Split In Batches').item.json.premium || 0 }} },\n    \"Policy Status\": { \"select\": { \"name\": \"Active\" } },\n    \"NowCerts Last Synced\": { \"date\": { \"start\": \"{{ new Date().toISOString() }}\" } },\n    \"Sync Status\": { \"select\": { \"name\": \"Synced\" } },\n    \"Sync Source\": { \"select\": { \"name\": \"NowCerts\" } },\n    \"Id\": { \"rich_text\": [{ \"text\": { \"content\": \"{{ $('🔄 Split In Batches').item.json.nowcertsId }}\" } }] }\n  }\n}",

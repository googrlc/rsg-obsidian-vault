      "parameters": {
        "jsCode": "/* BUILD SLACK SUMMARY */\n\nconst items = $('🔧 Normalize Policies').all();\nconst total = items.length;\n\nconst timeStr = new Date().toLocaleString('en-US', {\n  timeZone: 'America/New_York',\n  month: 'short',\n  day: 'numeric',\n  hour: 'numeric',\n  minute: '2-digit',\n  hour12: true\n});\n\nconst message = [\n  '*NowCerts → Notion Policy Sync Complete* — ' + timeStr,\n  '',\n  '*Policies synced:* *' + total + '*',\n  '',\n  '_Next sync: ' + (new Date().getHours() < 14 ? '2:00 PM' : '6:00 AM tomorrow') + '_'\n].join('\\n');\n\nreturn [{ json: { message } }];"
      },
